generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  MECHANIC
  DRIVER
}

enum BusStatus {
  ACTIVE
  STANDBY
  INACTIVE
  MAINTENANCE
}

enum TicketStatus {
  OPEN
  ENROUTE
  RESOLVED
}

enum ShiftLifecycleStatus {
  ASSIGNED
  HANDED_OVER
  ON_ROUTE
  COMPLETED
  CLOSED
}

enum RemittanceStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

model User {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  email     String?  @unique
  password  String
  role      Role
  isActive  Boolean  @default(true)
  approvedAt DateTime?
  createdAt DateTime @default(now())
  driverLocation DriverLocation?
}

model Route {
  id         String   @id @default(uuid())
  name       String
  startPoint String
  endPoint   String
  startLat   Float?
  startLng   Float?
  endLat     Float?
  endLng     Float?
  plannedDistanceKm    Float?
  targetDurationMinutes Int?
  turnaroundMinutes     Int?
  plannedTripsPerShift  Int?
  peakHeadwayMinutes    Int?
  offPeakHeadwayMinutes Int?
  createdAt  DateTime @default(now())

  buses Bus[]
}

model Bus {
  id          String    @id @default(uuid())
  plateNumber String    @unique
  model       String
  status      BusStatus @default(STANDBY)
  gpsDeviceId String?
  routeId     String
  createdAt   DateTime  @default(now())

  route       Route               @relation(fields: [routeId], references: [id])
  shifts      Shift[]
  remittances Remittance[]
  maintenance MaintenanceTicket[]
}

model Driver {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  licenseNo String
  createdAt DateTime @default(now())

  shifts      Shift[]
  remittances Remittance[]
}

model Shift {
  id        String   @id @default(uuid())
  busId     String
  driverId  String
  startTime DateTime
  endTime   DateTime
  confirmed Boolean  @default(false)
  status    ShiftLifecycleStatus @default(ASSIGNED)
  issuedAt  DateTime?
  issuedByUserId String?
  handoverConfirmedAt DateTime?
  handoverConfirmedByUserId String?
  tripStartedAt DateTime?
  completedAt DateTime?
  closedAt DateTime?
  closedByUserId String?
  odometerOut Int?
  odometerIn Int?
  fuelOutPercent Int?
  fuelInPercent Int?
  handoverNotes String?
  returnNotes String?
  plannedTripsTarget Int?
  targetDurationMinutesSnapshot Int?
  completedTrips Int @default(0)
  completedLoops Int @default(0)
  passengerCount Int @default(0)
  actualDurationMinutes Int?
  tripPerformanceNotes String?

  bus    Bus    @relation(fields: [busId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])
  remittances Remittance[]
}

model Remittance {
  id             String   @id @default(uuid())
  busId          String
  driverId       String
  shiftId        String?
  date           DateTime
  expectedAmount Int
  reportedAmount Int
  approved       Boolean  @default(false)
  status         RemittanceStatus @default(PENDING)
  varianceAmount Int      @default(0)
  varianceReason String?
  reviewNotes    String?
  reviewedAt     DateTime?
  reviewedByUserId String?
  createdAt      DateTime @default(now())

  bus    Bus    @relation(fields: [busId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])
  shift  Shift? @relation(fields: [shiftId], references: [id])
}

model MaintenanceTicket {
  id         String       @id @default(uuid())
  busId      String
  issue      String
  status     TicketStatus @default(OPEN)
  diagnosis  String?
  repairNotes String?
  partsUsed   String?
  assignedMechanicName String?
  workStartedAt DateTime?
  workshopPriority Int?
  brakeChecked Boolean @default(false)
  engineChecked Boolean @default(false)
  tireChecked Boolean @default(false)
  electricalChecked Boolean @default(false)
  roadTestPassed Boolean @default(false)
  returnedToServiceAt DateTime?
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?

  bus Bus @relation(fields: [busId], references: [id])
}

model RemittanceConfig {
  id             Int      @id
  expectedAmount Int      @default(25000)
  updatedAt      DateTime @updatedAt
}

model DriverLocation {
  id         String   @id @default(uuid())
  userId     String   @unique
  busId      String?
  lat        Float
  lng        Float
  speedKph   Float?
  heading    Float?
  accuracyM  Float?
  recordedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}
